<?
	header( "content-type:text/html;charset=utf-8");
	require_once( "./class_inc/config.inc" );
	require_once( "./class_inc/crypt.inc" );
	require_once( "./class_inc/login.inc" );
	require_once( "./class_inc/database.inc" );
	$strID  = trim($_POST['userid']);
	$strPass= trim($_POST['passwd']);
	$bSaveID= false;
	if( $_POST['idsave'] == 'Y' ) $bSaveID= true;
// 로그아웃

	if( $_POST['logout'] == 'Y' ) 
	{
		
		$hLogin = new CLogin( "tb_mst_admin", "admin_id", "admin_pass", "admin_seq", "admin_name", "admin_level" );
		$hLogin->Logout();
		echo "<script>parent.location.replace('".CONFIG_DOC_ROOT."');</script>";
		exit;
	}
// 로그인
	if( $strID != "" )
	{
		$hLogin = new CLogin( "tb_mst_admin", "admin_id", "admin_pass", "admin_seq", "admin_name", "admin_level" );
	//	$hLogin->SetAllowIP( "221.148.239.*", "61.74.215.71"  );
		$nResult = $hLogin->Login( $strID, $strPass, $bSaveID, false );
		switch( $nResult )
		{
			case -1:  echo "<script>alert('".IDS_LOGIN_EXIST."');    parent.FORM_LOGIN.userid.value=''; parent.FORM_LOGIN.userid.focus();</script>"; exit;
			case -2:  echo "<script>alert('".IDS_LOGIN_PASSWORD."'); parent.FORM_LOGIN.userid.passwd=''; parent.FORM_LOGIN.passwd.focus();</script>"; exit;
			case -3:  echo "<script>alert('".IDS_LOGIN_DENYIP."');  </script> "; exit;
		}
		echo "<script>parent.location.replace('".$_SERVER["PHP_SELF"]."');</script>";
	} else

// 로그인창
	{
		$hLogin		= new CLogin();
		$strSavedID = $hLogin->GetCookie( "admin_id" );
	}
?>
<html>
<head>
<LINK REL=STYLESHEET TYPE="text/css" HREF="<?=CONFIG_DOC_ROOT?>/css/index.css">
<title><?=IDS_SITE_NAME?></title>
</head>
