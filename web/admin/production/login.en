<!--
function CheckForm()
{
	var hForm = document.FORM_LOGIN;
	if(hForm.userid.value == "")		{ alert('<?=IDS_LOGIN_INPUT_ID?>');  hForm.userid.focus(); return false;	}
	else if(hForm.passwd.value == "")	{ alert('<?=IDS_LOGIN_INPUT_PASS?>');hForm.passwd.focus(); return false;	}
}

function SetDefaultFocus()
{
	if(document.FORM_LOGIN.userid.value == "")  document.FORM_LOGIN.userid.focus();
	else										document.FORM_LOGIN.passwd.focus();
}

function boxMsg()
{
	if(document.FORM_LOGIN.idsave.checked == true)
	{
		if(confirm('<?=IDS_LOGIN_IDSAVE_CONFIRM?>') == false)
		{
			document.FORM_LOGIN.idsave.checked = false;
		}
	}
}
//-->
</script>
<body Onload="SetDefaultFocus();" topmargin="0" leftmargin="0">
<form name="FORM_LOGIN" method="post" action="<?=$PHP_SELF?>" OnSubmit="return CheckForm()" target="noshow">
