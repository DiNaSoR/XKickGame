  <table width="100%" height="100%"  border="0" cellpadding="0" cellspacing="0">
    <tr>
      <td>
	  <table width="100" border="0" align="center" cellpadding="0" cellspacing="0">
        <tr>
          <td rowspan="3"><img src="image/login_left.gif" width="117" height="214"></td>
          <td><img src="image/login_top.gif" width="317" height="47"></td>
          <td rowspan="3"><img src="image/login_right.gif" width="24" height="214"></td>
        </tr>
        <tr>
          <td height="88" bgcolor="3A3A3A">
<!-- 로그인테이블 시작 -->		  
		  <table width="303" border="0" cellspacing="0" cellpadding="0">
            <tr>
              <td width="88" height="20" align="right"><img src="image/id.gif" width="85" height="5"></td>
              <td width="110"><input name="userid" type="text" size="18" maxlength="15" tabindex="1" value="<?=$strSavedID?>"></td>
              <td width="98" rowspan="2" align="center"><input type="image" src="image/B_login.gif" width="66" height="41" border="0" tabindex="3"></td>
			  <td rowspan="2" align="center"> &nbsp;<input type="checkbox" name="idsave" value="Y" onclick="boxMsg();"<?if($strSavedID)echo" checked";?>></td>
            </tr>
            <tr>
              <td height="20" align="right"><img src="image/pw.gif" width="85" height="5"></td>
              <td><input name="passwd" type="password" size="18" maxlength="15" tabindex="2"></td>
            </tr>
          </table>
<!-- 로그인테이블 끝 -->		  
		  </td>
          </tr>
        <tr>
          <td><img src="image/login_bottom.gif" width="317" height="79"></td>
          </tr>
      </table>      
	  </td>
    </tr>
